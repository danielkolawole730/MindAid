{
  "name": "mind-aid",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "description": "mental health check",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "develop": "concurrently \"cd server && npm run watch\" \"cd client && npm start\"",
    "install": "cd server && npm i && cd ../client && npm i",
    "seed": "cd server && npm run seed",
    "build": "cd client && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitrotap/mental-health-check.git"
  },
  "keywords": [
    "mental-health",
    "depression",
    "anxiety",
    "schizophrenia",
    "post-traumatic-stress"
  ],
  "author": "nitrotap",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nitrotap/mental-health-check/issues"
  },
  "homepage": "https://github.com/nitrotap/mental-health-check#readme",
  "devDependencies": {
    "concurrently": "^7.2.0"
  },
  "dependencies": {
    "@faker-js/faker": "^6.3.1",
    "apollo-server-express": "^3.7.0",
    "bcrypt": "^5.0.1",
    "chart.js": "^4.4.1",
    "express": "^4.18.1",
    "graphql": "^16.5.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.3.3",
    "stripe": "^9.1.0"
  }
}
